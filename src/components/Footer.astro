---
// Site footer — dark surface with brand, site nav, and legal links.
---

<footer class="footer" aria-label="Site footer">
  <div class="footer-grid">
    <div class="footer-brand">
      <p class="footer-brand__name">Action Sports Safety Project</p>
      <p class="footer-brand__desc">
        Life-saving education for the action sports community. Tuition grants for medical
        certifications. Emergency response training at community events.
      </p>
      <dl class="footer-trust">
        <div class="footer-trust__item">
          <dt style="display:inline;">Organization:</dt>
          <dd style="display:inline;"> 501(c)(3) Public Benefit Corporation</dd>
        </div>
        <div class="footer-trust__item">
          <dt style="display:inline;">State:</dt>
          <dd style="display:inline;"> California</dd>
        </div>
        <div class="footer-trust__item">
          <dt style="display:inline;">Tax ID (EIN):</dt>
          <dd style="display:inline;"> Available upon request</dd>
        </div>
      </dl>
    </div>

    <div class="footer-col">
      <p class="footer-col__heading">Site</p>
      <nav class="footer-nav" aria-label="Site navigation">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/programs">Programs</a>
        <a href="/donate">Donate</a>
        <a href="/grants">Grant Submissions</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>

    <div class="footer-col">
      <p class="footer-col__heading">Legal</p>
      <nav class="footer-nav" aria-label="Legal links">
        <a href="/terms">Terms of Use</a>
        <a href="/privacy">Privacy Policy</a>
        <a href="/disclosures">State Disclosures</a>
        <a href="mailto:info@actionsportssafetyproject.com">info@actionsportssafetyproject.com</a>
      </nav>
    </div>
  </div>

  <div class="footer-bottom">
    <p class="footer-copy">&copy; 2024 Action Sports Safety Project. All rights reserved.</p>
    <p class="footer-legal">
      Donations are tax-deductible to the extent permitted by law. No goods or services are
      provided in exchange for charitable contributions.
    </p>
  </div>
</footer>
