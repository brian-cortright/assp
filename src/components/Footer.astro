---
import { client } from '../lib/sanity';
import { siteSettingsQuery } from '../lib/queries';

interface NavItem { label: string; href: string }
interface SiteSettings {
  siteName?: string;
  footerDescription?: string;
  taxStatus?: string;
  state?: string;
  taxId?: string;
  contactEmail?: string;
  foundingYear?: number;
  footerSiteHeading?: string;
  footerSiteLinks?: NavItem[];
  footerLegalHeading?: string;
  footerLegalLinks?: NavItem[];
  footerLegalDisclaimer?: string;
}

const settings: SiteSettings = (await client.fetch(siteSettingsQuery)) || {};
const year = new Date().getFullYear();
const foundingYear = settings.foundingYear ?? 2024;
const copyrightYear = year > foundingYear ? `${foundingYear}–${year}` : `${foundingYear}`;
const email = settings.contactEmail ?? 'info@actionsportssafetyproject.com';
const siteName = settings.siteName ?? 'Action Sports Safety Project';

const siteHeading = settings.footerSiteHeading ?? 'Site';
const siteLinks: NavItem[] = settings.footerSiteLinks?.length
  ? settings.footerSiteLinks
  : [
      { label: 'Home', href: '/' },
      { label: 'About', href: '/about' },
      { label: 'Programs', href: '/programs' },
      { label: 'Donate', href: '/donate' },
      { label: 'Grant Submissions', href: '/grants' },
      { label: 'Contact', href: '/contact' },
    ];

const legalHeading = settings.footerLegalHeading ?? 'Legal';
const legalLinks: NavItem[] = settings.footerLegalLinks?.length
  ? settings.footerLegalLinks
  : [
      { label: 'Terms of Use', href: '/terms' },
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'State Disclosures', href: '/disclosures' },
      { label: email, href: `mailto:${email}` },
    ];

const isExternal = (href: string) =>
  /^(https?:|mailto:|tel:)/.test(href);
---

<footer class="footer" aria-label="Site footer">
  <div class="footer-grid">
    <div class="footer-brand">
      <p class="footer-brand__name">{siteName}</p>
      <p class="footer-brand__desc">
        {settings.footerDescription ??
          'Life-saving education for the action sports community. Tuition grants for medical certifications. Emergency response training at community events.'}
      </p>
      <dl class="footer-trust">
        <div class="footer-trust__item">
          <dt>Organization</dt>
          <dd>{settings.taxStatus ?? '501(c)(3) Public Benefit Corporation'}</dd>
        </div>
        <div class="footer-trust__item">
          <dt>State</dt>
          <dd>{settings.state ?? 'California'}</dd>
        </div>
        <div class="footer-trust__item">
          <dt>Tax ID (EIN)</dt>
          <dd>{settings.taxId ?? 'Available upon request'}</dd>
        </div>
      </dl>
    </div>

    <div class="footer-col">
      <p class="footer-col__heading">{siteHeading}</p>
      <nav class="footer-nav" aria-label="Site navigation">
        {siteLinks.map((link) => (
          <a
            href={link.href}
            target={isExternal(link.href) ? '_blank' : undefined}
            rel={isExternal(link.href) ? 'noopener noreferrer' : undefined}
          >{link.label}</a>
        ))}
      </nav>
    </div>

    <div class="footer-col">
      <p class="footer-col__heading">{legalHeading}</p>
      <nav class="footer-nav" aria-label="Legal links">
        {legalLinks.map((link) => (
          <a
            href={link.href}
            target={isExternal(link.href) ? '_blank' : undefined}
            rel={isExternal(link.href) ? 'noopener noreferrer' : undefined}
          >{link.label}</a>
        ))}
      </nav>
    </div>
  </div>

  <div class="footer-bottom">
    <p class="footer-copy">&copy; {copyrightYear} {siteName}. All rights reserved.</p>
    {settings.footerLegalDisclaimer && (
      <p class="footer-legal">{settings.footerLegalDisclaimer}</p>
    )}
  </div>
</footer>
