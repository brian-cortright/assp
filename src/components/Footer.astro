---
import { client } from '../lib/sanity';
import { siteSettingsQuery } from '../lib/queries';

interface SiteSettings {
  siteName?: string;
  footerDescription?: string;
  taxStatus?: string;
  state?: string;
  taxId?: string;
  contactEmail?: string;
  foundingYear?: number;
}

const settings: SiteSettings = (await client.fetch(siteSettingsQuery)) || {};
const year = new Date().getFullYear();
const foundingYear = settings.foundingYear ?? 2024;
const copyrightYear = year > foundingYear ? `${foundingYear}–${year}` : `${foundingYear}`;
const email = settings.contactEmail ?? 'info@actionsportssafetyproject.com';
const siteName = settings.siteName ?? 'Action Sports Safety Project';
---

<footer class="footer" aria-label="Site footer">
  <div class="footer-grid">
    <div class="footer-brand">
      <p class="footer-brand__name">{siteName}</p>
      <p class="footer-brand__desc">
        {settings.footerDescription ??
          'Life-saving education for the action sports community. Tuition grants for medical certifications. Emergency response training at community events.'}
      </p>
      <dl class="footer-trust">
        <div class="footer-trust__item">
          <dt style="display:inline;">Organization:</dt>
          <dd style="display:inline;"> {settings.taxStatus ?? '501(c)(3) Public Benefit Corporation'}</dd>
        </div>
        <div class="footer-trust__item">
          <dt style="display:inline;">State:</dt>
          <dd style="display:inline;"> {settings.state ?? 'California'}</dd>
        </div>
        <div class="footer-trust__item">
          <dt style="display:inline;">Tax ID (EIN):</dt>
          <dd style="display:inline;"> {settings.taxId ?? 'Available upon request'}</dd>
        </div>
      </dl>
    </div>

    <div class="footer-col">
      <p class="footer-col__heading">Site</p>
      <nav class="footer-nav" aria-label="Site navigation">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/programs">Programs</a>
        <a href="/donate">Donate</a>
        <a href="/grants">Grant Submissions</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>

    <div class="footer-col">
      <p class="footer-col__heading">Legal</p>
      <nav class="footer-nav" aria-label="Legal links">
        <a href="/terms">Terms of Use</a>
        <a href="/privacy">Privacy Policy</a>
        <a href="/disclosures">State Disclosures</a>
        <a href={`mailto:${email}`}>{email}</a>
      </nav>
    </div>
  </div>

  <div class="footer-bottom">
    <p class="footer-copy">&copy; {copyrightYear} {siteName}. All rights reserved.</p>
    <p class="footer-legal">
      Donations are tax-deductible to the extent permitted by law. No goods or services are
      provided in exchange for charitable contributions.
    </p>
  </div>
</footer>
