---
/**
 * Grant application embed. The intake itself lives in a Google Form; this
 * component renders the page chrome (eyebrow / heading / lede) followed by
 * the embedded form so applicants don't leave the site.
 *
 * The embed URL is sourced from Sanity (grantsPage.formUrl). We force
 * `embedded=true` so Google strips its own header chrome.
 */

interface Props {
  id?: string;
  eyebrow?: string;
  heading?: string;
  lede?: string;
  requiredNote?: string;
  fineprint?: string;
  formUrl?: string;
  formHeight?: number;
}
const {
  id = 'apply',
  eyebrow: eyebrowProp,
  heading: headingProp,
  lede: ledeProp,
  requiredNote: requiredNoteProp,
  fineprint: fineprintProp,
  formUrl,
  formHeight = 1900,
} = Astro.props;

const eyebrow = eyebrowProp ?? 'Apply';
const heading = headingProp ?? 'Apply for a grant';
const lede =
  ledeProp ??
  'Tell us who you are, what you ride, and what happened. We read every one. Most riders hear back inside a week.';
const requiredNote = requiredNoteProp ?? 'All fields below are required.';
const fineprint =
  fineprintProp ??
  'Applicant details stay with the review committee. The privacy policy spells out exactly what we keep and for how long.';

let embedSrc: string | null = null;
if (formUrl) {
  try {
    const u = new URL(formUrl);
    u.searchParams.set('embedded', 'true');
    embedSrc = u.toString();
  } catch {
    embedSrc = formUrl;
  }
}
---

<section class="give-form give-form--grant" id={id} aria-labelledby={`${id}-h`}>
  <div class="give-form__inner">
    <header class="give-form__head">
      <p class="give-form__eyebrow" aria-hidden="true">{eyebrow}</p>
      <h2 class="give-form__heading" id={`${id}-h`}>{heading}</h2>
      <p class="give-form__lede">{lede}</p>
      {requiredNote && <p class="give-form__required-note">{requiredNote}</p>}
    </header>

    {embedSrc ? (
      <div class="give-form__embed">
        <iframe
          src={embedSrc}
          title={heading}
          loading="lazy"
          width="100%"
          height={formHeight}
          frameborder="0"
          marginheight="0"
          marginwidth="0"
        >
          Loading the application form…
        </iframe>
      </div>
    ) : (
      <p class="give-form__lede">
        The application form is being set up. Check back shortly.
      </p>
    )}

    {fineprint && <p class="give-form__fineprint">{fineprint}</p>}
  </div>
</section>

<style>
  .give-form__embed {
    width: 100%;
  }
  .give-form__embed iframe {
    display: block;
    width: 100%;
    max-width: 100%;
    border: 0;
    background: #fff;
  }
</style>
