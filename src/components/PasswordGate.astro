---
/**
 * Client-side password gate. NOT real security — anyone who reads the
 * page source can extract the hash and brute-force it. Use it only to
 * deter casual visitors / search engines while the site is in soft launch.
 *
 * To change the password:
 *   1. Compute the SHA-256 hex of your new password:
 *        echo -n "your-password" | shasum -a 256
 *   2. Replace PASSWORD_HASH below.
 */

// SHA-256 of "assp-preview" — change in production.
const PASSWORD_HASH = 'd03621da074b62a18e66d07600ed85e2506390122d3b5a8696bba9bf7c124a5f';
const STORAGE_KEY = 'assp-gate-ok-v1';
---

<div id="gate-root" data-hash={PASSWORD_HASH} data-storage-key={STORAGE_KEY} hidden>
  <div class="gate-overlay" role="dialog" aria-modal="true" aria-labelledby="gate-title">
    <form id="gate-form" class="gate-card" autocomplete="off">
      <h1 id="gate-title" class="gate-title">Action Sports Safety Project</h1>
      <p class="gate-sub">This site is in private preview. Enter the access code to continue.</p>
      <label class="gate-label" for="gate-input">Access code</label>
      <input
        id="gate-input"
        type="password"
        autocomplete="off"
        autocapitalize="off"
        autocorrect="off"
        spellcheck="false"
        required
      />
      <button type="submit" class="gate-button">Enter</button>
      <p id="gate-error" class="gate-error" hidden>Incorrect code.</p>
    </form>
  </div>
</div>

<script is:inline>
  (function () {
    const root = document.getElementById('gate-root');
    if (!root) return;
    const expected = root.dataset.hash;
    const storageKey = root.dataset.storageKey;

    if (sessionStorage.getItem(storageKey) === '1') return;

    // Hide page content until unlocked.
    document.documentElement.style.overflow = 'hidden';
    root.hidden = false;

    const sha256 = async (text) => {
      const data = new TextEncoder().encode(text);
      const buf = await crypto.subtle.digest('SHA-256', data);
      return [...new Uint8Array(buf)]
        .map((b) => b.toString(16).padStart(2, '0'))
        .join('');
    };

    const form = document.getElementById('gate-form');
    const input = document.getElementById('gate-input');
    const err = document.getElementById('gate-error');
    input.focus();

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      err.hidden = true;
      const hash = await sha256(input.value);
      if (hash === expected) {
        sessionStorage.setItem(storageKey, '1');
        document.documentElement.style.overflow = '';
        root.remove();
      } else {
        err.hidden = false;
        input.select();
      }
    });
  })();
</script>

<style>
  .gate-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: grid;
    place-items: center;
    background: #2D4A3E;
    padding: 1.5rem;
  }
  .gate-card {
    background: #FAF7F2;
    color: #1C1917;
    border-radius: 6px;
    padding: 2.5rem 2rem;
    width: 100%;
    max-width: 26rem;
    box-shadow: 0 24px 60px rgba(28, 25, 23, 0.35);
    font-family: 'Inter', system-ui, sans-serif;
  }
  .gate-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.5rem;
    margin: 0 0 0.5rem;
    line-height: 1.2;
  }
  .gate-sub {
    font-size: 0.95rem;
    color: #8B8178;
    margin: 0 0 1.5rem;
    line-height: 1.45;
  }
  .gate-label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.4rem;
    color: #8B8178;
  }
  .gate-card input {
    width: 100%;
    box-sizing: border-box;
    font: inherit;
    padding: 0.65rem 0.75rem;
    border: 1px solid #C6BFB5;
    border-radius: 4px;
    background: #FAF7F2;
    color: inherit;
  }
  .gate-card input:focus {
    outline: 2px solid #C4622D;
    outline-offset: 1px;
  }
  .gate-button {
    margin-top: 1rem;
    width: 100%;
    font: inherit;
    font-weight: 600;
    padding: 0.7rem 1rem;
    background: #C4622D;
    color: #FAF7F2;
    border: 0;
    border-radius: 4px;
    cursor: pointer;
  }
  .gate-button:hover { background: #A24E20; }
  .gate-error {
    margin: 0.85rem 0 0;
    color: #A24E20;
    font-size: 0.9rem;
  }
</style>
