---
import { client } from '../lib/sanity';
import { siteSettingsQuery } from '../lib/queries';

interface NavLink {
  label: string;
  href: string;
  variant?: string;
  external?: boolean;
}

interface SiteSettings {
  siteName?: string;
  tagline?: string;
  navLinks?: NavLink[];
}

const settings: SiteSettings = (await client.fetch(siteSettingsQuery)) || {};
const navLinks: NavLink[] = settings.navLinks?.length
  ? settings.navLinks
  : [
      { label: 'About', href: '/about' },
      { label: 'Programs', href: '/programs' },
      { label: 'Grants', href: '/grants' },
      { label: 'Contact', href: '/contact' },
      { label: 'Donate', href: '/donate', variant: 'primary' },
    ];
---

<nav class="nav" id="site-nav" aria-label="Main navigation">
  <a href="/" class="nav-logo" aria-label={`${settings.siteName ?? 'Action Sports Safety Project'}, home`}>
    <span class="nav-logo__name">{settings.siteName ?? 'Action Sports Safety Project'}</span>
    {settings.tagline && (
      <span class="nav-logo__tag" aria-hidden="true">{settings.tagline}</span>
    )}
  </a>
  <ul class="nav-links" role="list">
    {navLinks.map((link) => (
      <li>
        <a
          href={link.href}
          class={link.variant === 'primary' ? 'nav-donate' : undefined}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
        >{link.label}</a>
      </li>
    ))}
  </ul>
  <button
    class="nav-burger"
    id="nav-burger"
    aria-controls="nav-drawer"
    aria-expanded="false"
    aria-label="Open navigation menu"
  >
    <span></span><span></span><span></span>
  </button>
</nav>

<nav class="nav-drawer" id="nav-drawer" aria-label="Mobile navigation" aria-hidden="true">
  {navLinks.map((link) => (
    <a
      href={link.href}
      class={`drawer-link${link.variant === 'primary' ? ' drawer-donate' : ''}`}
      target={link.external ? '_blank' : undefined}
      rel={link.external ? 'noopener noreferrer' : undefined}
    >{link.label}</a>
  ))}
</nav>

<script>
  const nav = document.getElementById('site-nav');
  const hero = document.querySelector('.hero');
  if (nav && hero) {
    const navObserver = new IntersectionObserver(
      ([entry]) => nav.classList.toggle('nav--scrolled', !entry.isIntersecting),
      { threshold: 0, rootMargin: '-56px 0px 0px 0px' }
    );
    navObserver.observe(hero);
  }

  const burger = document.getElementById('nav-burger');
  const drawer = document.getElementById('nav-drawer');
  if (burger && drawer) {
    const drawerLinks = drawer.querySelectorAll('a');
    const openDrawer = () => {
      burger.setAttribute('aria-expanded', 'true');
      drawer.classList.add('is-open');
      drawer.removeAttribute('aria-hidden');
      document.body.style.overflow = 'hidden';
      (drawerLinks[0] as HTMLElement | undefined)?.focus();
    };
    const closeDrawer = () => {
      burger.setAttribute('aria-expanded', 'false');
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      burger.focus();
    };
    burger.addEventListener('click', () => {
      burger.getAttribute('aria-expanded') === 'true' ? closeDrawer() : openDrawer();
    });
    drawerLinks.forEach((link) => link.addEventListener('click', closeDrawer));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer.classList.contains('is-open')) closeDrawer();
    });
  }
</script>
