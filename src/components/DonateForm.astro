---
/**
 * Donation embed. Processing happens inside a Zeffy donation form; this
 * component renders the page chrome (eyebrow / heading / lede) and embeds
 * the form so donors don't leave the site.
 *
 * The embed URL is sourced from Sanity (donatePage.formUrl). For a Zeffy
 * "donation-form" URL we swap the path to "/embed/donation-form/" so the
 * iframe-friendly version is rendered.
 */

interface Props {
  id?: string;
  eyebrow?: string;
  heading?: string;
  lede?: string;
  requiredNote?: string;
  fineprint?: string;
  formUrl?: string;
  formHeight?: number;
}

const {
  id = 'give',
  eyebrow: eyebrowProp,
  heading: headingProp,
  lede: ledeProp,
  requiredNote: requiredNoteProp,
  fineprint: fineprintProp,
  formUrl,
  formHeight = 550,
} = Astro.props;

const heading = headingProp ?? 'Give now';
const eyebrow = eyebrowProp ?? 'Donate';
const lede =
  ledeProp ??
  "Pick a number that means something to you. Leave your name and email. The online processor isn't wired up yet; when it is, you'll be first in line. Until then, the offline routes are below.";
const requiredNote = requiredNoteProp ?? 'Name, email, and an amount are required.';
const fineprint =
  fineprintProp ?? 'Tax-deductible to the extent permitted by law. EIN on request, no form to fill out.';

let embedSrc: string | null = null;
if (formUrl) {
  try {
    const u = new URL(formUrl);
    if (u.hostname.endsWith('zeffy.com')) {
      u.pathname = u.pathname.replace('/donation-form/', '/embed/donation-form/');
    }
    embedSrc = u.toString();
  } catch {
    embedSrc = formUrl;
  }
}
---

<section class="give-form" id={id} aria-labelledby={`${id}-h`}>
  <div class="give-form__inner">
    <header class="give-form__head">
      <p class="give-form__eyebrow" aria-hidden="true">{eyebrow}</p>
      <h2 class="give-form__heading" id={`${id}-h`}>{heading}</h2>
      <p class="give-form__lede">{lede}</p>
      {requiredNote && <p class="give-form__required-note">{requiredNote}</p>}
    </header>

    {embedSrc ? (
      <div class="give-form__embed">
        <iframe
          src={embedSrc}
          title={heading}
          loading="lazy"
          width="100%"
          height={formHeight}
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          allow="payment *; clipboard-write"
          allowtransparency="true"
        >
          Loading the donation form…
        </iframe>
      </div>
    ) : (
      <p class="give-form__lede">
        The donation form is being set up. Check back shortly.
      </p>
    )}

    {fineprint && <p class="give-form__fineprint">{fineprint}</p>}
  </div>
</section>

<style>
  .give-form__embed {
    width: 100%;
  }
  .give-form__embed iframe {
    display: block;
    width: 100%;
    max-width: 100%;
    border: 0;
    background: #fff;
  }
</style>
