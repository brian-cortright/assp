---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PortableText from '../components/PortableText.astro';
import { client } from '../lib/sanity';
import { donatePageQuery } from '../lib/queries';

const page = (await client.fetch(donatePageQuery)) || {};
---

<Base title={page.seo?.title} description={page.seo?.description}>
  <Header />

  <main id="main-content">
    <section class="page-hero" aria-labelledby="donate-title">
      <div class="page-hero-inner">
        <div>
          {page.hero?.eyebrow && <p class="page-hero-eyebrow" aria-hidden="true">{page.hero.eyebrow}</p>}
          <h1 class="page-hero-title" id="donate-title">{page.hero?.title}</h1>
        </div>
        {page.hero?.lede && <p class="page-hero-lede">{page.hero.lede}</p>}
      </div>
    </section>

    {page.impactRungs && page.impactRungs.length > 0 && (
      <section class="impact" aria-labelledby="impact-h">
        <div class="impact-inner">
          <div>
            {page.impactEyebrow && <p class="impact-eyebrow" aria-hidden="true">{page.impactEyebrow}</p>}
            <h2 class="impact-headline" id="impact-h">{page.impactHeadline}</h2>
            {page.impactSubheadline && <p class="impact-sub">{page.impactSubheadline}</p>}
          </div>

          <div>
            <ol class="impact-ladder" aria-label="Where your donation goes">
              {page.impactRungs.map((rung) => (
                <li class="impact-rung">
                  <span class="impact-rung__amount">{rung.amount}</span>
                  <p class="impact-rung__body">
                    <strong>{rung.title}</strong>
                    {rung.body && <> {rung.body}</>}
                  </p>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </section>
    )}

    <section class="page-section page-section--dust" aria-labelledby="give-h">
      <div class="page-split">
        <aside class="page-aside">
          <p class="page-aside__heading">Three ways to give</p>
          <ul class="page-aside__list">
            <li><a href="#online">Online</a></li>
            <li><a href="#check">By check</a></li>
            <li><a href="#stock">Stock or DAF</a></li>
            <li><a href="#match">Employer match</a></li>
          </ul>
        </aside>

        <div class="prose">
          <PortableText value={page.howToGiveBody} />
          {page.disclaimer && (
            <>
              <hr />
              <p style="font-size: var(--t-sm); color: var(--c-text-3);">{page.disclaimer}</p>
            </>
          )}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
