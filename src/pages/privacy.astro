---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PortableText from '../components/PortableText.astro';
import { client } from '../lib/sanity';
import { legalPageQuery } from '../lib/queries';

const page = (await client.fetch(legalPageQuery, { slug: 'privacy' })) || {};
---

<Base title={page.seo?.title} description={page.seo?.description}>
  <Header />

  <main id="main-content">
    <section class="page-hero" aria-labelledby="privacy-title">
      <div class="page-hero-inner">
        <div>
          {page.hero?.eyebrow && <p class="page-hero-eyebrow" aria-hidden="true">{page.hero.eyebrow}</p>}
          <h1 class="page-hero-title" id="privacy-title">{page.hero?.title || page.title}</h1>
        </div>
        {page.hero?.lede && <p class="page-hero-lede">{page.hero.lede}</p>}
      </div>
    </section>

    <section class="page-section">
      <div class="page-section-inner">
        {(page.effectiveDate || page.lastUpdated) && (
          <p class="prose-meta">
            {page.effectiveDate && <span>Effective date: {page.effectiveDate}</span>}
            {page.lastUpdated && <span>Last updated: {page.lastUpdated}</span>}
          </p>
        )}
        <div class="prose">
          <PortableText value={page.body} />
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
