---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { client } from '../lib/sanity';
import { programsPageQuery } from '../lib/queries';

interface Cta { label: string; href: string; variant?: string; external?: boolean }
interface Program { number?: string; label?: string; title?: string; bodyParagraphs?: string[]; metaTags?: string[]; cta?: Cta }
interface PageData {
  hero?: { eyebrow?: string; title?: string; lede?: string };
  programs?: Program[];
  donateCTAEyebrow?: string;
  donateCTAHeadline?: string;
  donateCTACta?: Cta;
  seo?: { title?: string; description?: string };
}

const page = (await client.fetch<PageData>(programsPageQuery)) || {};
const ctaClass = (c?: Cta, fallback = 'btn-primary') =>
  c?.variant ? `btn btn-${c.variant}` : `btn ${fallback}`;
---

<Base title={page.seo?.title} description={page.seo?.description}>
  <Header />

  <main id="main-content">
    <section class="page-hero" aria-labelledby="programs-title">
      <div class="page-hero-inner">
        <div>
          {page.hero?.eyebrow && <p class="page-hero-eyebrow" aria-hidden="true">{page.hero.eyebrow}</p>}
          <h1 class="page-hero-title" id="programs-title">{page.hero?.title}</h1>
        </div>
        {page.hero?.lede && <p class="page-hero-lede">{page.hero.lede}</p>}
      </div>
    </section>

    {page.programs && page.programs.length > 0 && (
      <section class="programs">
        <div class="programs-inner">
          {page.programs.map((prog) => (
            <article class="program">
              <div>
                <p class="program-index">
                  {prog.number && <span class="program-index__num">{prog.number}</span>}
                  {prog.label && <span>{prog.label}</span>}
                </p>
                <h2 class="program-title">{prog.title}</h2>
              </div>
              <div>
                {(prog.bodyParagraphs || []).map((para) => (
                  <p class="program-body">{para}</p>
                ))}
                {prog.metaTags && prog.metaTags.length > 0 && (
                  <p class="program-meta">
                    {prog.metaTags.map((tag) => <span>{tag}</span>)}
                  </p>
                )}
                {prog.cta && (
                  <p class="program-cta">
                    <a href={prog.cta.href} class={ctaClass(prog.cta)}>{prog.cta.label}</a>
                  </p>
                )}
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {(page.donateCTAHeadline || page.donateCTACta) && (
      <section class="donate-cta" aria-labelledby="programs-cta">
        <div class="donate-cta-inner">
          <div>
            {page.donateCTAEyebrow && <p class="donate-cta-eyebrow" aria-hidden="true">{page.donateCTAEyebrow}</p>}
            <h2 class="donate-cta-headline" id="programs-cta">{page.donateCTAHeadline}</h2>
          </div>
          {page.donateCTACta && (
            <div class="donate-cta-actions">
              <a href={page.donateCTACta.href} class={ctaClass(page.donateCTACta, 'btn-white')}>{page.donateCTACta.label}</a>
            </div>
          )}
        </div>
      </section>
    )}
  </main>

  <Footer />
</Base>
