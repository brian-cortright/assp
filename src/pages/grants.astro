---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PortableText from '../components/PortableText.astro';
import GrantForm from '../components/GrantForm.astro';
import { client } from '../lib/sanity';
import { grantsPageQuery } from '../lib/queries';

const page = (await client.fetch(grantsPageQuery)) || {};
---

<Base title={page.seo?.title} description={page.seo?.description}>
  <Header />

  <main id="main-content">
    <section class="page-hero" aria-labelledby="grants-title">
      <div class="page-hero-inner">
        <div>
          {page.hero?.eyebrow && <p class="page-hero-eyebrow" aria-hidden="true">{page.hero.eyebrow}</p>}
          <h1 class="page-hero-title" id="grants-title">{page.hero?.title}</h1>
        </div>
        <div>
          {page.hero?.lede && <p class="page-hero-lede">{page.hero.lede}</p>}
          <p class="page-hero-actions">
            <a href="#apply" class="btn btn-white">Start an application</a>
          </p>
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="page-split">
        <aside class="page-aside">
          <p class="page-aside__heading">How it works</p>
          <ul class="page-aside__list">
            <li><a href="#eligibility">Eligibility</a></li>
            <li><a href="#approved-courses">Approved courses</a></li>
            <li><a href="#process">Process</a></li>
            <li><a href="#timeline">Timeline</a></li>
            <li><a href="#apply">Apply</a></li>
          </ul>
        </aside>

        <div class="prose">
          <PortableText value={page.body} />
        </div>
      </div>
    </section>

    <GrantForm id="apply" />
  </main>

  <Footer />
</Base>
