---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PortableText from '../components/PortableText.astro';
import GrantForm from '../components/GrantForm.astro';
import { client } from '../lib/sanity';
import { grantsPageQuery } from '../lib/queries';

interface NavItem { label: string; href: string }
interface FormCopy {
  eyebrow?: string; heading?: string; lede?: string; requiredNote?: string;
  submitLabel?: string; fineprint?: string; noticeHeading?: string; noticeBody?: string;
}
interface PageHero { eyebrow?: string; title?: string; lede?: string }
interface GrantsPage {
  hero?: PageHero;
  applyButtonLabel?: string;
  tocHeading?: string;
  tocLinks?: NavItem[];
  body?: any[];
  form?: FormCopy;
  formUrl?: string;
  formDisciplineOptions?: string[];
  formKindOptions?: string[];
  formUrgentEmail?: string;
  seo?: { title?: string; description?: string };
}

const page: GrantsPage = (await client.fetch<GrantsPage>(grantsPageQuery)) || {};

const tocLinks: NavItem[] = page.tocLinks?.length
  ? page.tocLinks
  : [
      { label: 'Eligibility', href: '#eligibility' },
      { label: 'Approved courses', href: '#approved-courses' },
      { label: 'Process', href: '#process' },
      { label: 'Timeline', href: '#timeline' },
      { label: 'Apply', href: '#apply' },
    ];
---

<Base title={page.seo?.title} description={page.seo?.description}>
  <Header />

  <main id="main-content">
    <section class="page-hero" aria-labelledby="grants-title">
      <div class="page-hero-inner">
        <div>
          {page.hero?.eyebrow && <p class="page-hero-eyebrow" aria-hidden="true">{page.hero.eyebrow}</p>}
          <h1 class="page-hero-title" id="grants-title">{page.hero?.title}</h1>
        </div>
        <div>
          {page.hero?.lede && <p class="page-hero-lede">{page.hero.lede}</p>}
          <p class="page-hero-actions">
            <a href="#apply" class="btn btn-white">{page.applyButtonLabel ?? 'Apply for a grant'}</a>
          </p>
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="page-split">
        <aside class="page-aside">
          <p class="page-aside__heading">{page.tocHeading ?? 'How it works'}</p>
          <ul class="page-aside__list">
            {tocLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </aside>

        <div class="prose">
          <PortableText value={page.body} />
        </div>
      </div>
    </section>

    <GrantForm
      id="apply"
      eyebrow={page.form?.eyebrow}
      heading={page.form?.heading}
      lede={page.form?.lede}
      requiredNote={page.form?.requiredNote}
      fineprint={page.form?.fineprint}
      formUrl={page.formUrl}
    />
  </main>

  <Footer />
</Base>
