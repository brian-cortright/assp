---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PortableText from '../components/PortableText.astro';
import { client } from '../lib/sanity';
import { aboutPageQuery, boardMembersQuery } from '../lib/queries';

const [page, board] = await Promise.all([
  client.fetch(aboutPageQuery),
  client.fetch(boardMembersQuery),
]);
const p = page || {};
---

<Base title={p.seo?.title} description={p.seo?.description}>
  <Header />

  <main id="main-content">
    <section class="page-hero" aria-labelledby="about-title">
      <div class="page-hero-inner">
        <div>
          {p.hero?.eyebrow && <p class="page-hero-eyebrow" aria-hidden="true">{p.hero.eyebrow}</p>}
          <h1 class="page-hero-title" id="about-title">{p.hero?.title}</h1>
        </div>
        {p.hero?.lede && <p class="page-hero-lede">{p.hero.lede}</p>}
      </div>
    </section>

    <section class="page-section">
      <div class="page-split">
        <aside class="page-aside" aria-label="On this page">
          <p class="page-aside__heading">On this page</p>
          <ul class="page-aside__list">
            <li><a href="#mission">Our mission</a></li>
            <li><a href="#origin">Origin</a></li>
            <li><a href="#values">What we believe</a></li>
            <li><a href="#board">Board of directors</a></li>
            <li><a href="#governance">Governance</a></li>
          </ul>
        </aside>

        <div class="prose">
          <h2 id="mission">Our mission</h2>
          <PortableText value={p.missionBody} />

          <h2 id="origin">Origin</h2>
          <PortableText value={p.originBody} />

          <h2 id="values">What we believe</h2>
          <PortableText value={p.valuesBody} />

          <h2 id="board">Board of directors</h2>
          <ul class="board-grid" role="list" style="list-style:none; margin:var(--s-6) 0; padding:0;">
            {(board || []).map((member) => (
              <li class="board-card">
                <span class="board-monogram" aria-hidden="true">{member.initials}</span>
                <p class="board-name">{member.name}</p>
                <p class="board-role">{member.role}</p>
              </li>
            ))}
          </ul>

          <h2 id="governance">Governance</h2>
          <PortableText value={p.governanceBody} />
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
