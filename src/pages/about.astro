---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PortableText from '../components/PortableText.astro';
import { client } from '../lib/sanity';
import { aboutPageQuery, boardMembersQuery } from '../lib/queries';

interface BoardMember { name?: string; role?: string }
interface PageHero { eyebrow?: string; title?: string; lede?: string }
interface AboutPage {
  hero?: PageHero;
  missionBody?: any[];
  originBody?: any[];
  valuesBody?: any[];
  governanceBody?: any[];
  boardHeadline?: string;
  boardSubheadline?: string;
  seo?: { title?: string; description?: string };
}

const [page, board] = (await Promise.all([
  client.fetch(aboutPageQuery),
  client.fetch(boardMembersQuery),
])) as [AboutPage | null, BoardMember[] | null];
const p: AboutPage = page || {};
const boardList: BoardMember[] = board || [];
---

<Base title={p.seo?.title} description={p.seo?.description}>
  <Header />

  <main id="main-content">
    <section class="page-hero" aria-labelledby="about-title">
      <div class="page-hero-inner">
        <div>
          {p.hero?.eyebrow && <p class="page-hero-eyebrow" aria-hidden="true">{p.hero.eyebrow}</p>}
          <h1 class="page-hero-title" id="about-title">{p.hero?.title}</h1>
        </div>
        {p.hero?.lede && <p class="page-hero-lede">{p.hero.lede}</p>}
      </div>
    </section>

    <section class="page-section">
      <div class="page-split">
        <aside class="page-aside" aria-label="On this page">
          <p class="page-aside__heading">On this page</p>
          <ul class="page-aside__list">
            <li><a href="#mission">Our mission</a></li>
            <li><a href="#origin">Origin</a></li>
            <li><a href="#values">What we believe</a></li>
            <li><a href="#board">Board of directors</a></li>
            <li><a href="#governance">Governance</a></li>
          </ul>
        </aside>

        <div class="prose">
          <h2 id="mission">Our mission</h2>
          <PortableText value={p.missionBody} />

          <h2 id="origin">Origin</h2>
          <PortableText value={p.originBody} />

          <h2 id="values">What we believe</h2>
          <PortableText value={p.valuesBody} />

          <h2 id="governance">Governance</h2>
          <PortableText value={p.governanceBody} />
        </div>
      </div>
    </section>

    {boardList.length > 0 && (
      <section class="board" id="board" aria-labelledby="board-headline">
        <div class="board-inner">
          <div class="board-intro">
            <p class="section-eyebrow" aria-hidden="true">Who we are</p>
            <h2 class="section-headline" id="board-headline">{p.boardHeadline ?? 'Board of directors'}</h2>
            {p.boardSubheadline && (
              <p class="section-sub section-sub--flush">{p.boardSubheadline}</p>
            )}
          </div>

          <ol class="board-roster" role="list">
            {boardList.map((member, i) => (
              <li class="board-row">
                <span class="board-index" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                <p class="board-name">{member.name}</p>
                <p class="board-role">{member.role}</p>
              </li>
            ))}
          </ol>
        </div>
      </section>
    )}
  </main>

  <Footer />
</Base>
