---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Topography from '../components/Topography.astro';
import { client, urlFor } from '../lib/sanity';
import { homePageQuery } from '../lib/queries';

interface Cta { label: string; href: string; variant?: string; external?: boolean }
interface NavItem { label: string; href: string }
interface EditorialImage { asset?: unknown; alt?: string }
interface Program { number?: string; label?: string; title?: string; bodyParagraphs?: string[]; metaTags?: string[]; image?: EditorialImage; cta?: Cta }
interface ImpactRung { amount?: string; title?: string; body?: string; image?: EditorialImage }
interface HomePage {
  heroEyebrow?: string; heroHeadline?: string; heroSubheadline?: string;
  heroPrimaryCta?: Cta; heroSecondaryCta?: Cta;
  heroImage?: EditorialImage;
  heroTocIndex?: string; heroTocLinks?: NavItem[];
  problemHeadline?: string; problemBodyParagraphs?: string[];
  programsSectionEyebrow?: string; programsSectionHeadline?: string; programs?: Program[];
  impactEyebrow?: string; impactHeadline?: string; impactSubheadline?: string;
  impactRungs?: ImpactRung[]; impactNote?: string;
  donateCTAEyebrow?: string; donateCTAHeadline?: string;
  donateCTAPrimaryCta?: Cta; donateCTASecondaryCta?: Cta;
  seo?: { title?: string; description?: string };
}

const home = await client.fetch<HomePage>(homePageQuery);
const h = home || {};
const ctaClass = (c?: Cta, fallback = 'btn-primary') =>
  c?.variant ? `btn btn-${c.variant}` : `btn ${fallback}`;

const heroTocLinks: NavItem[] = h.heroTocLinks?.length
  ? h.heroTocLinks
  : [
      { label: 'Problem', href: '#problem' },
      { label: 'Programs', href: '#programs' },
      { label: 'Impact', href: '#impact' },
      { label: 'Donate', href: '#donate' },
    ];
---

<Base title={h.seo?.title} description={h.seo?.description}>
  <Header />

  <main id="main-content">
    <!-- HERO -->
    <section class="hero" aria-labelledby="hero-headline">
      <Topography />
      <div class="hero-inner">
        {h.heroEyebrow && <p class="hero-eyebrow" aria-hidden="true" set:html={h.heroEyebrow.replace(/·/g, '&nbsp;·&nbsp;')}></p>}
        <h1 class="hero-headline" id="hero-headline">{h.heroHeadline}</h1>
        {h.heroSubheadline && <p class="hero-sub">{h.heroSubheadline}</p>}
        <div class="hero-actions">
          {h.heroPrimaryCta && (
            <a href={h.heroPrimaryCta.href} class={ctaClass(h.heroPrimaryCta, 'btn-white')}>{h.heroPrimaryCta.label}</a>
          )}
          {h.heroSecondaryCta && (
            <a href={h.heroSecondaryCta.href} class={ctaClass(h.heroSecondaryCta, 'btn-outline')}>{h.heroSecondaryCta.label}</a>
          )}
        </div>
      </div>
      <div class="hero-rule" aria-hidden="true"></div>
      <nav class="hero-toc" aria-label="On this page">
        <span class="hero-toc__line" aria-hidden="true"></span>
        {h.heroTocIndex && <span class="hero-toc__index" aria-hidden="true">{h.heroTocIndex}</span>}
        <ol class="hero-toc__list" role="list">
          {heroTocLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ol>
      </nav>
    </section>

    <!-- HERO INTERSTITIAL — full-bleed 3:2 landscape photo. Hidden when no image. -->
    {h.heroImage?.asset && (
      <figure class="hero-interstitial">
        <img
          src={urlFor(h.heroImage)!.width(2000).fit('crop').url()}
          srcset={`${urlFor(h.heroImage)!.width(900).fit('crop').url()} 900w, ${urlFor(h.heroImage)!.width(1400).fit('crop').url()} 1400w, ${urlFor(h.heroImage)!.width(2000).fit('crop').url()} 2000w`}
          sizes="100vw"
          alt={h.heroImage.alt ?? ''}
          loading="eager"
          decoding="async"
          width="2000"
          height="1333"
        />
      </figure>
    )}

    <!-- PROBLEM -->
    {h.problemHeadline && (
      <section class="problem" id="problem" aria-labelledby="problem-headline">
        <div class="problem-inner">
          <h2 class="problem-statement" id="problem-headline">{h.problemHeadline}</h2>
          <div>
            {(h.problemBodyParagraphs || []).map((para) => (
              <p class="problem-body" set:html={para.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')}></p>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- PROGRAMS -->
    {h.programs && h.programs.length > 0 && (
      <section class="programs" id="programs" aria-labelledby="programs-headline">
        <div class="programs-inner">
          <header class="programs-entrance">
            {h.programsSectionEyebrow && <p class="programs-entrance__eyebrow" aria-hidden="true">{h.programsSectionEyebrow}</p>}
            <h2 class="programs-entrance__headline" id="programs-headline">{h.programsSectionHeadline}</h2>
          </header>

          {h.programs.map((prog, i) => (
            <article class={`program${prog.image?.asset ? ' program--with-photo' : ''}${i % 2 === 1 ? ' program--photo-left' : ''}`}>
              <div class="program-head">
                <p class="program-index">
                  {prog.number && <span class="program-index__num">{prog.number}</span>}
                  {prog.label && <span>{prog.label}</span>}
                </p>
                <h3 class="program-title">{prog.title}</h3>
              </div>
              <div class="program-text">
                {(prog.bodyParagraphs || []).map((para) => (
                  <p class="program-body">{para}</p>
                ))}
                {prog.metaTags && prog.metaTags.length > 0 && (
                  <p class="program-meta">
                    {prog.metaTags.map((tag) => <span>{tag}</span>)}
                  </p>
                )}
              </div>
              {prog.image?.asset && (
                <figure class="program-photo">
                  <img
                    src={urlFor(prog.image)!.width(900).height(900).fit('crop').url()}
                    srcset={`${urlFor(prog.image)!.width(600).height(600).fit('crop').url()} 600w, ${urlFor(prog.image)!.width(900).height(900).fit('crop').url()} 900w, ${urlFor(prog.image)!.width(1200).height(1200).fit('crop').url()} 1200w`}
                    sizes="(min-width: 1024px) 30vw, 100vw"
                    alt={prog.image.alt ?? ''}
                    loading="lazy"
                    decoding="async"
                    width="900"
                    height="900"
                  />
                </figure>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- IMPACT — ladder leads. Framing text demoted to a footer beneath. -->
    {h.impactRungs && h.impactRungs.length > 0 && (
      <section class="impact" id="impact" aria-labelledby="impact-headline">
        <div class="impact-inner">
          {h.impactEyebrow && <p class="impact-kicker" aria-hidden="true">{h.impactEyebrow}</p>}

          <ol class="impact-ladder" aria-label="Where your donation goes">
            {h.impactRungs.map((rung) => (
              <li class={`impact-rung${rung.image?.asset ? ' impact-rung--with-photo' : ''}`}>
                <span class="impact-rung__amount">{rung.amount}</span>
                <p class="impact-rung__body">
                  <strong>{rung.title}</strong>
                  {rung.body && <> {rung.body}</>}
                </p>
                {rung.image?.asset && (
                  <figure class="impact-rung__photo">
                    <img
                      src={urlFor(rung.image)!.width(700).height(700).fit('crop').url()}
                      srcset={`${urlFor(rung.image)!.width(500).height(500).fit('crop').url()} 500w, ${urlFor(rung.image)!.width(700).height(700).fit('crop').url()} 700w`}
                      sizes="(min-width: 1024px) 30vw, 100vw"
                      alt={rung.image.alt ?? ''}
                      loading="lazy"
                      decoding="async"
                      width="700"
                      height="700"
                    />
                  </figure>
                )}
              </li>
            ))}
          </ol>

          {(h.impactHeadline || h.impactSubheadline || h.impactNote) && (
            <footer class="impact-footer">
              {h.impactHeadline && <h2 class="impact-footer__headline" id="impact-headline">{h.impactHeadline}</h2>}
              {h.impactSubheadline && <p class="impact-footer__sub">{h.impactSubheadline}</p>}
              {h.impactNote && <p class="impact-note">{h.impactNote}</p>}
            </footer>
          )}
        </div>
      </section>
    )}

    <!-- DONATE CTA -->
    {(h.donateCTAHeadline || h.donateCTAPrimaryCta) && (
      <section class="donate-cta" id="donate" aria-labelledby="donate-cta-headline">
        <div class="donate-cta-inner">
          <div>
            {h.donateCTAEyebrow && <p class="donate-cta-eyebrow" aria-hidden="true">{h.donateCTAEyebrow}</p>}
            <h2 class="donate-cta-headline" id="donate-cta-headline">{h.donateCTAHeadline}</h2>
          </div>
          <div class="donate-cta-actions">
            {h.donateCTAPrimaryCta && (
              <a href={h.donateCTAPrimaryCta.href} class={ctaClass(h.donateCTAPrimaryCta, 'btn-primary')}>{h.donateCTAPrimaryCta.label}</a>
            )}
            {h.donateCTASecondaryCta && (
              <a href={h.donateCTASecondaryCta.href} class={ctaClass(h.donateCTASecondaryCta, 'btn-ghost')}>{h.donateCTASecondaryCta.label}</a>
            )}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
</Base>
