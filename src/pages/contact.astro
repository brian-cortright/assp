---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { client } from '../lib/sanity';
import { contactPageQuery } from '../lib/queries';

interface PageHero { eyebrow?: string; title?: string; lede?: string }
interface ContactChannel { label?: string; value?: string; href?: string }
interface FaqItem { question?: string; answer?: string }
interface ContactPage {
  hero?: PageHero;
  channels?: ContactChannel[];
  faq?: FaqItem[];
  seo?: { title?: string; description?: string };
}

const page: ContactPage = (await client.fetch<ContactPage>(contactPageQuery)) || {};

function slugify(s: string): string {
  return s
    .toLowerCase()
    .replace(/[^\w\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-');
}
---

<Base title={page.seo?.title} description={page.seo?.description}>
  <Header />

  <main id="main-content">
    <section class="page-hero" aria-labelledby="contact-title">
      <div class="page-hero-inner">
        <div>
          {page.hero?.eyebrow && <p class="page-hero-eyebrow" aria-hidden="true">{page.hero.eyebrow}</p>}
          <h1 class="page-hero-title" id="contact-title">{page.hero?.title}</h1>
        </div>
        {page.hero?.lede && <p class="page-hero-lede">{page.hero.lede}</p>}
      </div>
    </section>

    <section class="page-section">
      <div class="page-section-inner">
        {page.channels && page.channels.length > 0 && (
          <dl class="fact-grid">
            {page.channels.map((ch) => (
              <div class="fact">
                <dt>{ch.label}</dt>
                <dd>
                  {ch.href
                    ? <a href={ch.href}>{ch.value}</a>
                    : ch.value}
                </dd>
              </div>
            ))}
          </dl>
        )}

        {page.faq && page.faq.length > 0 && (
          <>
            <hr class="contact-divider" />
            <div class="prose prose-narrow">
              <h2 id="faq">Frequently asked</h2>
              <ul class="faq-list" role="list">
                {page.faq.map((item) => {
                  const slug = item.question ? `faq-${slugify(item.question)}` : undefined;
                  return (
                    <li class="faq-item" id={slug}>
                      <details>
                        <summary>
                          <h3 class="faq-item__q">{item.question}</h3>
                          <span class="faq-item__icon" aria-hidden="true"></span>
                        </summary>
                        <div class="faq-item__a">
                          <p>{item.answer}</p>
                        </div>
                      </details>
                    </li>
                  );
                })}
              </ul>
            </div>
          </>
        )}
      </div>
    </section>
  </main>

  <Footer />
</Base>

<script>
  /**
   * FAQ deep-linking: if the URL hash matches an faq-item, open its <details>
   * and move focus to the summary so screen reader users land on the
   * disclosure with state announced. Respects prefers-reduced-motion for
   * the scroll behavior.
   */
  function openFromHash() {
    const hash = window.location.hash;
    if (!hash || !hash.startsWith('#faq-')) return;
    const item = document.querySelector<HTMLLIElement>(hash);
    if (!item) return;
    const details = item.querySelector('details');
    const summary = item.querySelector<HTMLElement>('summary');
    if (details) details.open = true;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    summary?.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth', block: 'start' });
    summary?.focus();
  }

  window.addEventListener('hashchange', openFromHash);
  // Defer so layout settles; the section is statically rendered above the fold.
  document.addEventListener('DOMContentLoaded', openFromHash);
</script>
