---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Contact — Action Sports Safety Project"
  description="Get in touch with Action Sports Safety Project. Grant questions, donation help, on-site clinic requests, and press inquiries."
>
  <Header />

  <main id="main-content">
    <section class="page-hero" aria-labelledby="contact-title">
      <div class="page-hero-inner">
        <div>
          <p class="page-hero-eyebrow" aria-hidden="true">Contact</p>
          <h1 class="page-hero-title" id="contact-title">
            Reach the people doing the work.
          </h1>
        </div>
        <p class="page-hero-lede">
          We answer email. Pick the address that fits, or write the general inbox and we
          will route you. Replies within five business days.
        </p>
      </div>
    </section>

    <section class="page-section">
      <div class="page-section-inner">
        <dl class="fact-grid">
          <div class="fact">
            <dt>General</dt>
            <dd><a href="mailto:info@actionsportssafetyproject.com">info@actionsportssafetyproject.com</a></dd>
          </div>
          <div class="fact">
            <dt>Grant questions</dt>
            <dd><a href="mailto:grants@actionsportssafetyproject.com">grants@actionsportssafetyproject.com</a></dd>
          </div>
          <div class="fact">
            <dt>Donations</dt>
            <dd><a href="mailto:donate@actionsportssafetyproject.com">donate@actionsportssafetyproject.com</a></dd>
          </div>
          <div class="fact">
            <dt>On-site clinic requests</dt>
            <dd><a href="mailto:clinics@actionsportssafetyproject.com">clinics@actionsportssafetyproject.com</a></dd>
          </div>
          <div class="fact">
            <dt>Press</dt>
            <dd><a href="mailto:press@actionsportssafetyproject.com">press@actionsportssafetyproject.com</a></dd>
          </div>
          <div class="fact">
            <dt>Mailing address</dt>
            <dd>Available upon request</dd>
          </div>
        </dl>

        <hr style="margin: var(--s-12) 0; border: 0; border-top: 1px solid var(--c-border);" />

        <div class="prose prose-narrow">
          <h2>Frequently asked</h2>

          <h3>How quickly do you respond?</h3>
          <p>Within five business days. Usually sooner.</p>

          <h3>I want to volunteer. How?</h3>
          <p>
            Write the general inbox with your background and which program you want to
            help with. We are a small operation and respond to every offer.
          </p>

          <h3>Are you on social media?</h3>
          <p>
            We post sparingly. Better to email if you want a real answer.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
