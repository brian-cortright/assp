---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { client } from '../lib/sanity';
import { contactPageQuery } from '../lib/queries';

interface PageHero { eyebrow?: string; title?: string; lede?: string }
interface ContactChannel { label?: string; value?: string; href?: string }
interface FaqItem { question?: string; answer?: string }
interface ContactPage {
  hero?: PageHero;
  channels?: ContactChannel[];
  faq?: FaqItem[];
  seo?: { title?: string; description?: string };
}

const page: ContactPage = (await client.fetch<ContactPage>(contactPageQuery)) || {};
---

<Base title={page.seo?.title} description={page.seo?.description}>
  <Header />

  <main id="main-content">
    <section class="page-hero" aria-labelledby="contact-title">
      <div class="page-hero-inner">
        <div>
          {page.hero?.eyebrow && <p class="page-hero-eyebrow" aria-hidden="true">{page.hero.eyebrow}</p>}
          <h1 class="page-hero-title" id="contact-title">{page.hero?.title}</h1>
        </div>
        {page.hero?.lede && <p class="page-hero-lede">{page.hero.lede}</p>}
      </div>
    </section>

    <section class="page-section">
      <div class="page-section-inner">
        {page.channels && page.channels.length > 0 && (
          <dl class="fact-grid">
            {page.channels.map((ch) => (
              <div class="fact">
                <dt>{ch.label}</dt>
                <dd>
                  {ch.href
                    ? <a href={ch.href}>{ch.value}</a>
                    : ch.value}
                </dd>
              </div>
            ))}
          </dl>
        )}

        {page.faq && page.faq.length > 0 && (
          <>
            <hr style="margin: var(--s-12) 0; border: 0; border-top: 1px solid var(--c-border);" />
            <div class="prose prose-narrow">
              <h2>Frequently asked</h2>
              {page.faq.map((item) => (
                <>
                  <h3>{item.question}</h3>
                  <p>{item.answer}</p>
                </>
              ))}
            </div>
          </>
        )}
      </div>
    </section>
  </main>

  <Footer />
</Base>
